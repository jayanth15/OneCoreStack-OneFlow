# OneFlow Backend — Environment Variables
# Copy this file to .env and fill in the values

# App
DEBUG=false

# Database
# Dev (SQLite):
DATABASE_URL=sqlite:///./oneflow.db
# Prod (PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/oneflow

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — frontend origin(s)
CORS_ORIGINS=["http://localhost:3000"]

# Optional modules (uncomment to enable)
# MODULE_PLANNING=true
# MODULE_ROUTING=true
# MODULE_RESOURCES=true
# MODULE_OUTSOURCING=true
# MODULE_QUALITY=true
# MODULE_DISPATCH=true
