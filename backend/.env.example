# OneFlow Backend — Environment Variables
# Copy this file to .env and fill in the values

# App
DEBUG=false

# Database
# Dev (SQLite) — no DATABASE_URL needed; the app uses an absolute path in
#   backend/app/db/oneflow.db by default (the app/db/ folder is created automatically).
#
# Docker/Dokploy with a volume mount — mount the container path /app/app/db
# and the DB will be persisted. Or override with an absolute path (4 slashes):
#   DATABASE_URL=sqlite:////app/app/db/oneflow.db
#
# Prod (PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/oneflow

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — frontend origin(s)
CORS_ORIGINS=["http://localhost:3000"]

# Optional modules (uncomment to enable)
# MODULE_PLANNING=true
# MODULE_ROUTING=true
# MODULE_RESOURCES=true
# MODULE_OUTSOURCING=true
# MODULE_QUALITY=true
# MODULE_DISPATCH=true
