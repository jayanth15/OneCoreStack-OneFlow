# =============================================================================
# OneFlow — Monorepo .gitignore
# =============================================================================

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/settings.json
.idea/

# ─── Root-level generated files ───────────────────────────────────────────────
PLAN.md
oneflow.db
*.db
*.sqlite
*.sqlite3

# ─── Backend (Python / FastAPI) ───────────────────────────────────────────────

# Virtual environments
backend/venv/
backend/venv-*/
backend/.venv/

# Python bytecode
backend/**/__pycache__/
backend/**/*.py[cod]
backend/**/*.pyo
backend/**/*.pyd
backend/**/.Python

# Distribution / packaging
backend/dist/
backend/build/
backend/*.egg-info/
backend/*.egg

# Environment files (keep .env.example)
backend/.env
backend/.env.local
backend/.env.*.local

# Database files — exclude by default, except the bundled demo db
backend/*.db
backend/*.sqlite
backend/*.sqlite3
!backend/oneflow.db

# Logs
backend/**/*.log
backend/logs/

# Pytest / coverage
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.mypy_cache/
backend/.ruff_cache/

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# frontend/.gitignore covers Next.js specifics; these cover root-perspective rules

frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/

# Environment files (keep .env.example)
frontend/.env
frontend/.env.local
frontend/.env.*.local

# TypeScript build info
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Package manager debug logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
